      <div>
        <a class="brand footer-brand" href="/" aria-label="Kaiyu Select home">
          <span class="brand-mark" aria-hidden="true"><i></i><i></i></span>
          <span>Kaiyu <strong>Select</strong></span>
        </a>
        <p>Engineering services and selected products,<br />thoughtfully brought together.</p>
      </div>
      <div class="footer-column">
        <h2>Explore</h2>
        <a href="/engineering">Engineering</a>
        <a href="/products">Products</a>
        <a href="/projects">Projects</a>
      </div>
      <div class="footer-column">
        <h2>Company</h2>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <a href="mailto:contact@kaiyuselect.com.au">Email us</a>
      </div>
      <div class="footer-contact">
        <span>Get in touch</span>
        <a href="mailto:contact@kaiyuselect.com.au">contact@kaiyuselect.com.au <span aria-hidden="true">↗</span></a>
