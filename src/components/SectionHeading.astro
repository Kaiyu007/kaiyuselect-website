---
interface Props {
  eyebrow: string;
  heading: string;
  intro?: string;
  align?: 'left' | 'split';
}
const { eyebrow, heading, intro, align = 'left' } = Astro.props;
---

<div class:list={['section-heading', align]}>
  <div>
    <p class="eyebrow"><span></span>{eyebrow}</p>
    <h2>{heading}</h2>
  </div>
  {intro && <p class="section-intro">{intro}</p>}
</div>
