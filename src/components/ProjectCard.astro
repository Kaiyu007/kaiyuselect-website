---
interface Props {
  number?: string;
  category: string;
  title: string;
  shortDescription: string;
  tags: string[];
  image?: string;
  imageAlt?: string;
  projectUrl?: string;
  status?: string;
  imageFit?: 'cover' | 'contain';
  imagePosition?: string;
  linkLabel?: string;
}

const {
  number,
  category,
  title,
  shortDescription,
  tags,
  image,
  imageAlt = '',
  projectUrl,
  status = 'Case study in preparation',
  imageFit = 'cover',
  imagePosition = 'center',
  linkLabel = 'View Project',
} = Astro.props;
---

<article class:list={['project-card', image && 'has-image', !number && 'no-number']}>
  {image && (
    <div class:list={['project-media', `fit-${imageFit}`]}>
      <img src={image} alt={imageAlt} loading="lazy" decoding="async" style={`object-position: ${imagePosition};`} />
    </div>
  )}

  <div class="project-copy">
    <header class="project-card-header">
      {number && <span class="project-card-number">{number}</span>}
      <div>
        <p class="project-type">{category}</p>
        <h3>{title}</h3>
      </div>
    </header>

    <p class="project-description">{shortDescription}</p>

    <ul class="project-tags" aria-label={`${title} capabilities`}>
      {tags.map((tag) => <li>{tag}</li>)}
    </ul>

    <footer class="project-card-footer">
      {status && <span class="project-status"><i aria-hidden="true"></i>{status}</span>}
      {projectUrl && <a class="text-link" href={projectUrl}>{linkLabel} <span aria-hidden="true">↗</span></a>}
    </footer>
  </div>
</article>
