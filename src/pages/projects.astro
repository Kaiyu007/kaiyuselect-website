---
import BaseLayout from '../components/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ContactCta from '../components/ContactCta.astro';
import { projects } from '../data/site';
---

<BaseLayout title="Engineering Design Capabilities | Kaiyu Select Australia" description="Explore example Kaiyu Select capabilities in product design, CAD modelling, enclosure design and manufacturing-ready drawings.">
  <header class="page-hero">
    <div class="shell page-hero-grid">
      <div><p class="eyebrow"><span></span>Engineering capabilities</p><h1>Practical project<br />areas and outcomes.</h1></div>
      <div class="page-hero-copy"><p>Example service areas showing the types of engineering design work Kaiyu Select can support. They are capability examples, not claimed client case studies.</p></div>
    </div>
  </header>

  <section class="section">
    <div class="shell">
      <SectionHeading eyebrow="Example project areas" heading="From functional concepts to clear documentation." intro="These categories explain available service types and possible project outcomes without presenting them as completed client work." align="split" />
      <div class="notice"><p><strong>Portfolio development is ongoing.</strong> Real case studies will be added gradually when suitable work can be shared clearly and responsibly.</p></div>
      <div class="project-list">{projects.map((project) => <ProjectCard {...project} />)}</div>
    </div>
  </section>

  <ContactCta eyebrow="Your project" heading="What are you trying to make or improve?" text="Tell us about the project area, current stage, available reference information and the outcome you need." />
</BaseLayout>
