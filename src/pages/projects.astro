---
import BaseLayout from '../components/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { featuredProject, projects } from '../data/site';

const caseStudySteps = [
  { number: '01', title: 'Brief', description: 'The objective, constraints and available reference information.' },
  { number: '02', title: 'Development', description: 'The modelling, design decisions and revision process.' },
  { number: '03', title: 'Technical Output', description: 'The drawings, CAD files, analysis or prototype preparation completed.' },
  { number: '04', title: 'Outcome', description: 'The final agreed design direction and supplied deliverables.' },
];
---

<BaseLayout title="Engineering Projects & CAD Portfolio | Kaiyu Select" description="Explore the developing Kaiyu Select portfolio of CAD modelling, product design, technical drawings and prototype preparation projects in Australia.">
  <header class="page-hero engineering-hero projects-hero">
    <div class="shell page-hero-grid engineering-hero-grid">
      <div>
        <p class="eyebrow"><span></span>Engineering Portfolio</p>
        <h1>Selected Engineering Projects</h1>
      </div>
      <div class="page-hero-copy engineering-hero-copy">
        <p>A developing portfolio of CAD, product design, technical documentation and prototyping work. Selected projects will be added as they can be shared clearly and responsibly.</p>
        <div class="engineering-hero-actions">
          <a class="button" href="#project-grid">Explore Projects <span aria-hidden="true">↓</span></a>
          <a class="button button-outline" href="/contact/?type=project">Discuss a Project <span aria-hidden="true">↗</span></a>
        </div>
      </div>
    </div>
  </header>

  <section class="section section-white projects-portfolio-section" id="project-grid">
    <div class="shell">
      <SectionHeading eyebrow="Project Portfolio" heading="Practical design work, documented clearly." intro="This page presents selected engineering projects, design processes and final deliverables. The featured academic case study is documented below, alongside project areas being prepared for future case studies." align="split" />

      <p class="portfolio-note">Portfolio development is ongoing. No entry should be interpreted as a completed client case study unless it is clearly identified as one.</p>

      <div class="featured-project">
        <ProjectCard {...featuredProject} />
      </div>

      <div class="project-grid">
        {projects.map((project) => <ProjectCard {...project} />)}
      </div>
    </div>
  </section>

  <section class="section section-dark projects-process-section" aria-labelledby="projects-process-heading">
    <div class="shell">
      <SectionHeading eyebrow="What Each Case Study Will Show" heading="From requirements to final deliverables." />
      <div class="process-grid projects-process-grid">
        {caseStudySteps.map((step) => (
          <article class="process-step">
            <span>{step.number}</span>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="contact-cta" aria-labelledby="projects-cta-heading">
    <div class="shell contact-cta-inner">
      <div>
        <p class="eyebrow light"><span></span>Your Project</p>
        <h2 id="projects-cta-heading">Have a design problem or project idea?</h2>
      </div>
      <div>
        <p>Share the current stage, available files and intended outcome to receive a practical next step.</p>
        <a class="button button-light" href="/contact/?type=project">Discuss Your Project <span aria-hidden="true">↗</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
