---
import BaseLayout from '../components/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ContactCta from '../components/ContactCta.astro';
---

<BaseLayout title="About Kaiyu Select | Australian Engineering & Selected Products" description="Kaiyu Select is a founder-led Australian small business combining engineering design capability with practical everyday product selection.">
  <header class="page-hero">
    <div class="shell page-hero-grid">
      <div><p class="eyebrow"><span></span>About Kaiyu Select</p><h1>One brand.<br />Two practical paths.</h1></div>
      <div class="page-hero-copy"><p>Kaiyu Select is a founder-led Australian small business combining practical engineering capability with carefully considered everyday products.</p></div>
    </div>
  </header>

  <section class="section section-white">
    <div class="shell story-grid">
      <h2>Built gradually around practical thinking.</h2>
      <div class="story-copy">
        <p class="lead">The idea behind Kaiyu Select is simple: apply practical thinking to both design work and everyday product choices.</p>
        <p>Engineering services focus on helping people turn requirements, sketches and early ideas into useful CAD models, product design detail and clear drawings.</p>
        <p>The selected-products direction focuses on items with sensible function and genuine everyday relevance. That range is still being prepared and will develop gradually.</p>
        <p>Kaiyu Select is an early-stage, founder-led business—not a large company. Work is approached with clear communication, manageable scope, honest expectations and continuous improvement as the business develops.</p>
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="shell">
      <SectionHeading eyebrow="Working principles" heading="A grounded approach to design, selection and development." />
      <div class="principles-grid">
        <article class="principle"><span>01</span><h3>Practical first</h3><p>Function, constraints and the real use case guide decisions.</p></article>
        <article class="principle"><span>02</span><h3>Clear communication</h3><p>Plain language, agreed scope and realistic expectations from a small business.</p></article>
        <article class="principle"><span>03</span><h3>Continuous development</h3><p>Services and product selection are refined gradually through useful feedback and experience.</p></article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell section-heading split">
      <div><p class="eyebrow"><span></span>Based in Australia</p><h2>Local perspective.<br />Flexible support.</h2></div>
      <p class="section-intro">Kaiyu Select supports individuals, students, makers, start-ups, small businesses and product developers. Selected products are being prepared for gradual introduction through direct enquiries and local availability.</p>
    </div>
  </section>

  <ContactCta />
</BaseLayout>
