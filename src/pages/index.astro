---
import BaseLayout from '../components/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProductCard from '../components/ProductCard.astro';
import ContactCta from '../components/ContactCta.astro';
import { services, products } from '../data/site';
---

<BaseLayout title="Kaiyu Select | Engineering Design & Selected Products Australia" description="Kaiyu Select is an Australian small business offering practical engineering design, CAD modelling, product design support and selected everyday products.">
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="eyebrow"><span></span>Engineering + everyday utility</p>
        <h1>Engineering Ideas.<br /><em>Selected Products.</em></h1>
        <p class="hero-description">Kaiyu Select is an Australian small business combining practical engineering design services with carefully selected everyday products.</p>
        <div class="hero-actions">
          <a class="button" href="/contact?type=engineering">Discuss an Engineering Project <span aria-hidden="true">↗</span></a>
          <a class="button button-outline" href="/products">Explore Product Categories</a>
        </div>
      </div>
      <div class="hero-graphic" aria-hidden="true">
        <span class="graphic-label label-one">Design / Select / Refine</span>
        <div class="tech-orbit"><i class="axis-x"></i><i class="axis-y"></i><i class="node n1"></i><i class="node n2"></i><i class="node n3"></i></div>
        <span class="graphic-label label-two">Melbourne &amp; Townsville · Australia</span>
      </div>
    </div>
  </section>

  <section class="division-strip" aria-label="Our divisions">
    <div class="shell division-grid">
      <a class="division-card" href="/engineering">
        <span class="number">01</span>
        <div><h2>Engineering Services</h2><p>CAD modelling, product design support, manufacturing-ready drawings and practical project consultation.</p></div>
        <span class="arrow" aria-hidden="true">↗</span>
      </a>
      <a class="division-card" href="/products">
        <span class="number">02</span>
        <div><h2>Selected Products</h2><p>Phone accessories, MagSafe accessories, car accessories and everyday tech products being prepared for gradual release.</p></div>
        <span class="arrow" aria-hidden="true">↗</span>
      </a>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionHeading eyebrow="Engineering services" heading="Practical support from idea to usable design detail." intro="Flexible CAD modelling, product design, drawing and consultation support for individuals and small organisations." align="split" />
      <div class="services-grid">
        {services.slice(0, 4).map((service) => <ServiceCard {...service} />)}
      </div>
      <div class="section-action"><a class="text-link" href="/engineering">Explore all services <span aria-hidden="true">→</span></a></div>
    </div>
  </section>

  <section class="section section-white">
    <div class="shell">
      <SectionHeading eyebrow="Product range in preparation" heading="Useful by design. Selected with purpose." intro="Selected items will be introduced gradually, with an initial focus on phone accessories, MagSafe accessories, car accessories and everyday electronics." align="split" />
      <div class="products-grid">
        {products.slice(0, 2).map((product) => <ProductCard {...product} />)}
      </div>
      <div class="section-action"><a class="text-link" href="/products">View product categories <span aria-hidden="true">→</span></a></div>
    </div>
  </section>

  <ContactCta />
</BaseLayout>
