---
import BaseLayout from '../components/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';

const engineeringServices = [
  {
    number: '01',
    title: '3D CAD Modelling',
    description: 'Accurate parts and assemblies created from sketches, measurements, reference images or existing components.',
    examples: ['Parts and enclosures', 'Mechanical assemblies', 'SolidWorks, STEP and STL'],
    groups: [
      {
        title: 'Examples and applications',
        items: ['Product parts and components', 'Enclosures and housings', 'Brackets, mounts and fixtures', 'Replacement parts', 'Mechanical assemblies', 'Hinges, clips and simple mechanisms', 'Prototype geometry', 'Parts recreated from physical measurements'],
      },
      {
        title: 'Possible deliverables',
        items: ['SolidWorks part and assembly files', 'STEP', 'IGES', 'Parasolid', 'STL', 'Other agreed CAD formats'],
      },
    ],
    note: 'SolidWorks parts and assemblies can also be converted into front, top, side, isometric, section and detail drawing views. Formats and drawing content are agreed for each project.',
  },
  {
    number: '02',
    title: '2D CAD & Layout Drawings',
    description: 'Clear layouts, plans, profiles and dimensioned drawings prepared from sketches, PDFs, measurements or existing files.',
    examples: ['Equipment and site layouts', 'DWG and DXF drawings', 'Cutting profiles'],
    groups: [
      {
        title: 'Examples and applications',
        items: ['Equipment and machinery layouts', 'Workshop, workspace, site and space layouts', 'General arrangement drawings', 'Dimensioned component drawings', 'Fabrication and flat cutting profiles', 'Existing drawing revisions', 'Marked-up plan conversion', 'Simple schematic or assembly layouts'],
      },
      {
        title: 'Possible deliverables',
        items: ['DWG', 'DXF', 'PDF drawing sets', 'Print-ready sheets', 'Other agreed 2D formats'],
      },
    ],
    note: 'Work can begin from an existing PDF, CAD file, hand sketch, marked-up image or measurement set. This service does not provide certified architectural, civil or structural drawings.',
  },
  {
    number: '03',
    title: 'Product Design & Development',
    description: 'Functional products and components developed around their intended use, dimensions, mechanisms and manufacturing requirements.',
    examples: ['Product concepts', 'Enclosures, hinges and clips', 'Prototype-ready designs'],
    groups: [
      {
        title: 'Examples and applications',
        items: ['New product concepts', 'Product enclosures and cases', 'Clips, hinges, lids and locking features', 'Component interfaces and internal layouts', 'Assembly design', 'Ergonomic and usability considerations', 'Design refinement', 'Design for prototyping and manufacturing', 'Modification of an existing concept or product'],
      },
      {
        title: 'Starting information',
        items: ['A written idea or functional requirement', 'A hand sketch', 'Reference products', 'An existing prototype', 'An incomplete CAD model'],
      },
      {
        title: 'Possible deliverables',
        items: ['Concept and revision models', 'Design alternatives', 'Functional CAD assemblies', 'Prototype-ready files', 'Manufacturing drawings', 'Final agreed CAD files'],
      },
    ],
  },
  {
    number: '04',
    title: '3D Printing & CNC Support',
    description: 'CAD preparation and design adjustment for additive manufacturing, CNC cutting and physical prototyping.',
    examples: ['Print-ready files', 'CNC cutting profiles', 'Tolerance and clearance review'],
    groups: [
      {
        title: '3D printing support',
        items: ['Print-ready STL or 3MF files', 'Geometry repair and file checking', 'Wall thickness review', 'Clearance and tolerance planning', 'Splitting large models into printable parts', 'Assembly and joining features', 'Prototype design adjustments', 'Preparation for common FDM or resin printing processes'],
      },
      {
        title: 'CNC support',
        items: ['DXF or DWG cutting profiles', 'Flat component geometry and CNC-ready outlines', 'Hole and slot layouts', 'Panel and sheet component preparation', 'Basic nesting preparation where appropriate', 'Adjustment for available tools, cutters or material thickness'],
      },
    ],
    note: 'Physical printing or cutting may be available or arranged depending on material, dimensions, quantity, finish and machine availability. Production is reviewed and quoted separately.',
  },
  {
    number: '05',
    title: 'Technical Drawings, Visualisation & Engineering Analysis',
    description: 'Technical documentation, design visuals and preliminary analysis to support review, prototyping and supplier communication.',
    examples: ['Manufacturing drawings', 'Renderings and exploded views', 'Preliminary FEA'],
    groups: [
      {
        title: 'Drawings and visual communication',
        items: ['Dimensioned part and assembly drawings', 'Orthographic, section and detail views', 'Exploded and general arrangement drawings', 'Drawing notes, specifications and basic tolerances', 'Bills of materials', 'Technical illustrations', 'Product renderings and presentation images'],
      },
      {
        title: 'Preliminary analysis',
        items: ['Finite element analysis for agreed design comparisons', 'Identification of potential high-stress or high-deformation areas', 'Geometry refinement to support design development'],
      },
    ],
    note: 'Analysis scope, loads, restraints, materials and assumptions must be agreed before work begins.',
  },
];

const quoteChecklist = ['A short project description', 'Sketches, photos or existing files', 'Key dimensions and measurement units', 'Intended use', 'Required deliverables or file formats', 'Preferred timeline'];

const projectSpecificGroups = [
  {
    title: '3D CAD modelling',
    items: ['Photos from several angles when recreating an existing part', 'Connected or mating components', 'Required clearances or tolerances', 'Required CAD and export formats', 'Whether a 2D technical drawing is also required'],
  },
  {
    title: '2D CAD and layout work',
    items: ['Overall dimensions and scale information', 'Required sheet size or drawing format', 'Required dimensions, labels and notes', 'Whether the drawing is for planning, quoting, cutting, fabrication or presentation'],
  },
  {
    title: 'Product design',
    items: ['The problem, intended user and operating environment', 'Required functions, target size and expected loads', 'Components and preferred materials', 'Intended manufacturing method and quantity', 'Target cost or budget, if known'],
  },
  {
    title: '3D printing or CNC work',
    items: ['Required material, quantity and overall dimensions', 'Critical dimensions and tolerances', 'Machine or supplier limitations', 'Material or sheet thickness', 'Whether physical manufacture or file preparation is required'],
  },
  {
    title: 'Technical drawings or FEA',
    items: ['Drawing standards or supplier requirements', 'Materials, loads, restraints and connection conditions', 'Required outputs or results', 'Whether analysis is for preliminary comparison or formal verification', 'Any certification or professional sign-off requirements'],
  },
];

const workflow = [
  { number: '01', title: 'Send Requirements', description: 'Share the project objective, available files, dimensions and preferred timeline.' },
  { number: '02', title: 'Review and Quote', description: 'The scope, price, timeline, revisions and deliverables are confirmed.' },
  { number: '03', title: 'Design and Revision', description: 'The design is developed and shared for agreed review and revisions.' },
  { number: '04', title: 'Final File Delivery', description: 'Approved files are supplied in the agreed formats.' },
];
---

<BaseLayout title="Engineering Design & CAD Services Australia | Kaiyu Select" description="2D and 3D CAD modelling, product design, technical drawings, 3D printing and CNC preparation, visualisation and engineering analysis support in Australia.">
  <header class="page-hero engineering-hero">
    <div class="shell page-hero-grid engineering-hero-grid">
      <div>
        <p class="eyebrow"><span></span>Division 01 · Engineering</p>
        <h1>Engineering Design &amp; CAD Services</h1>
      </div>
      <div class="page-hero-copy engineering-hero-copy">
        <p>Practical 2D and 3D CAD, product design and manufacturing-ready support for prototypes and real-world projects.</p>
        <div class="engineering-hero-actions">
          <a class="button" href="#services">View Services <span aria-hidden="true">↓</span></a>
          <a class="button button-outline" href="/contact/?type=engineering">Request a Quote <span aria-hidden="true">↗</span></a>
        </div>
      </div>
    </div>
  </header>

  <section class="section section-white engineering-services-section" id="services">
    <div class="shell">
      <SectionHeading eyebrow="Engineering Services" heading="Focused support for practical design work." intro="CAD, product development and technical documentation for a defined task or several stages of development." align="split" />

      <div class="engineering-service-list">
        {engineeringServices.map((service) => (
          <article class="engineering-service-card">
            <header class="engineering-service-header">
              <span class="engineering-service-number">{service.number}</span>
              <div>
                <h3>{service.title}</h3>
                <p>{service.description}</p>
              </div>
            </header>

            <ul class="engineering-service-examples" aria-label={`${service.title} examples`}>
              {service.examples.map((example) => <li>{example}</li>)}
            </ul>

            <details class="engineering-service-details">
              <summary>
                <span class="engineering-details-label">
                  <span class="engineering-details-label-closed">View details</span>
                  <span class="engineering-details-label-open">Hide details</span>
                </span>
                <span class="engineering-enquiry-toggle" aria-hidden="true"></span>
              </summary>
              <div class="engineering-service-details-content">
                <div class:list={['engineering-service-groups', service.groups.length === 1 && 'single-group']}>
                  {service.groups.map((group) => (
                    <div class="engineering-service-group">
                      <h4>{group.title}</h4>
                      <ul>
                        {group.items.map((item) => <li>{item}</li>)}
                      </ul>
                    </div>
                  ))}
                </div>
                {service.note && <p class="engineering-service-note">{service.note}</p>}
              </div>
            </details>
          </article>
        ))}
      </div>

      <p class="engineering-disclaimer">Preliminary engineering analysis does not constitute statutory certification or independent engineering verification unless specifically agreed and completed by an appropriately qualified professional.</p>
    </div>
  </section>

  <section class="engineering-audience-section" aria-label="Who we work with">
    <div class="shell engineering-audience-strip">
      <p class="eyebrow"><span></span>Who we work with</p>
      <p>Supporting individuals, students, makers, start-ups, small businesses and product developers.</p>
    </div>
  </section>

  <section class="section section-white engineering-enquiry-section" aria-labelledby="enquiry-heading">
    <div class="shell">
      <SectionHeading eyebrow="Before You Enquire" heading="What to send for a quote" intro="Send the information currently available. Missing technical requirements can be clarified before work begins." align="split" />

      <ul class="engineering-quote-checklist">
        {quoteChecklist.map((item) => <li>{item}</li>)}
      </ul>
      <p class="engineering-quote-note">Additional technical information may be requested depending on the project type.</p>

      <details class="engineering-project-details">
        <summary>
          <span>Project-specific information</span>
          <span class="engineering-details-action">
            <span class="engineering-details-label">
              <span class="engineering-details-label-closed">View details</span>
              <span class="engineering-details-label-open">Hide details</span>
            </span>
            <span class="engineering-enquiry-toggle" aria-hidden="true"></span>
          </span>
        </summary>
        <div class="engineering-project-details-content">
          {projectSpecificGroups.map((group) => (
            <section>
              <h3>{group.title}</h3>
              <ul>
                {group.items.map((item) => <li>{item}</li>)}
              </ul>
            </section>
          ))}
        </div>
      </details>
    </div>
  </section>

  <section class="section section-dark engineering-workflow-section" aria-labelledby="workflow-heading">
    <div class="shell">
      <SectionHeading eyebrow="How It Works" heading="A straightforward design process." />
      <div class="process-grid engineering-process-grid">
        {workflow.map((step) => (
          <article class="process-step">
            <span>{step.number}</span>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="contact-cta" aria-labelledby="engineering-cta-heading">
    <div class="shell contact-cta-inner">
      <div>
        <p class="eyebrow light"><span></span>Discuss Your Project</p>
        <h2 id="engineering-cta-heading">Have a project in mind?</h2>
      </div>
      <div>
        <p>Share your idea, available files and preferred timeline to receive a practical next step.</p>
        <a class="button button-light" href="/contact/?type=engineering">Request an Engineering Quote <span aria-hidden="true">↗</span></a>
      </div>
    </div>
  </section>

  <script>
    document
      .querySelectorAll<HTMLElement>('.engineering-service-details > summary, .engineering-project-details > summary')
      .forEach((summary) => {
        summary.addEventListener('keydown', (event) => {
          if (event.key !== 'Enter' && event.key !== ' ') return;

          const details = summary.parentElement;
          if (!(details instanceof HTMLDetailsElement)) return;

          event.preventDefault();
          details.open = !details.open;
        });
      });
  </script>
</BaseLayout>
