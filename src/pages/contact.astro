---
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout title="Contact Kaiyu Select | Engineering and Product Enquiries" description="Contact Kaiyu Select about engineering design services, project requirements or selected product availability.">
  <header class="page-hero">
    <div class="shell page-hero-grid">
      <div><p class="eyebrow"><span></span>Contact</p><h1>Tell us what<br />you have in mind.</h1></div>
      <div class="page-hero-copy"><p>Whether it is an engineering project or a product question, a few useful details will help us point you in the right direction.</p></div>
    </div>
  </header>

  <section class="section">
    <div class="shell contact-grid">
      <aside class="contact-details">
        <p class="eyebrow"><span></span>Get in touch</p>
        <h2>A direct, straightforward conversation.</h2>
        <p>Kaiyu Select is a small business, so your enquiry is read and answered directly. Please allow a reasonable response time.</p>
        <div class="contact-method"><span>Email</span><a href="mailto:contact@kaiyuselect.com.au">contact@kaiyuselect.com.au</a></div>
        <ul class="enquiry-list">
          <li>Engineering service enquiries</li>
          <li>Project scope and consultation</li>
          <li>Product availability enquiries</li>
          <li>Local market information</li>
        </ul>
      </aside>

      <form id="contact-form" class="contact-form">
        <h2>Send an enquiry</h2>
        <p>Complete the form and your email application will prepare the message.</p>
        <div class="form-row">
          <div class="field"><label for="name">Name</label><input id="name" name="name" type="text" autocomplete="name" required /></div>
          <div class="field"><label for="email">Email</label><input id="email" name="email" type="email" autocomplete="email" required /></div>
        </div>
        <div class="field"><label for="enquiry-type">Enquiry type</label><select id="enquiry-type" name="enquiry-type" required><option value="">Select an option</option><option>Engineering service</option><option>Project consultation</option><option>Product availability</option><option>Local markets</option><option>General enquiry</option></select></div>
        <div class="field"><label for="subject">Subject</label><input id="subject" name="subject" type="text" required /></div>
        <div class="field"><label for="message">How can we help?</label><textarea id="message" name="message" required placeholder="For engineering enquiries, include the project stage, required outcome and any timeline. For products, tell us which category or item interests you."></textarea></div>
        <div class="form-actions">
          <button class="button" type="submit" aria-describedby="email-fallback">Prepare email <span aria-hidden="true">↗</span></button>
          <button id="copy-enquiry" class="button button-outline" type="button">Copy enquiry details</button>
        </div>
        <p id="copy-status" class="form-note copy-status" role="status" aria-live="polite" hidden>Enquiry details copied. Paste them into your preferred email app and send to contact@kaiyuselect.com.au.</p>
        <p id="email-fallback" class="form-note">If the email app does not open, please email <a href="mailto:contact@kaiyuselect.com.au">contact@kaiyuselect.com.au</a> directly.</p>
        <p class="form-note">This form does not store your information or submit to a database. It opens your default email application.</p>
      </form>
    </div>
  </section>

  <script>
    const form = document.querySelector<HTMLFormElement>('#contact-form');
    const copyButton = document.querySelector<HTMLButtonElement>('#copy-enquiry');
    const copyStatus = document.querySelector<HTMLElement>('#copy-status');

    const getFieldValue = (id: string) => {
      const field = document.getElementById(id);

      if (
        field instanceof HTMLInputElement ||
        field instanceof HTMLTextAreaElement ||
        field instanceof HTMLSelectElement
      ) {
        return field.value.trim();
      }

      return '';
    };

    const getEnquiryDetails = () => ({
      name: getFieldValue('name'),
      email: getFieldValue('email'),
      enquiryType: getFieldValue('enquiry-type'),
      subject: getFieldValue('subject'),
      message: getFieldValue('message'),
    });

    const buildEnquiryBody = (details: ReturnType<typeof getEnquiryDetails>) => [
      `Name: ${details.name}`,
      `Email: ${details.email}`,
      `Enquiry type: ${details.enquiryType}`,
      `Subject: ${details.subject}`,
      `Message: ${details.message}`,
    ].join('\n');

    const copyText = async (text: string) => {
      if (navigator.clipboard && window.isSecureContext) {
        await navigator.clipboard.writeText(text);
        return;
      }

      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.setAttribute('readonly', '');
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      const copied = document.execCommand('copy');
      textarea.remove();

      if (!copied) throw new Error('Clipboard copy was not available.');
    };

    form?.addEventListener('submit', (event) => {
      event.preventDefault();

      const details = getEnquiryDetails();
      const body = buildEnquiryBody(details);

      const mailtoUrl = `mailto:contact@kaiyuselect.com.au?subject=${encodeURIComponent(details.subject)}&body=${encodeURIComponent(body)}`;
      window.location.href = mailtoUrl;
    });

    copyButton?.addEventListener('click', async () => {
      if (!form?.reportValidity()) return;

      const details = getEnquiryDetails();
      const clipboardText = [
        'To: contact@kaiyuselect.com.au',
        buildEnquiryBody(details),
      ].join('\n');

      try {
        await copyText(clipboardText);
        if (copyStatus) copyStatus.hidden = false;
      } catch {
        if (copyStatus) {
          copyStatus.textContent = 'Copying was not available. Please email contact@kaiyuselect.com.au directly.';
          copyStatus.hidden = false;
        }
      }
    });

    form?.addEventListener('input', () => {
      if (copyStatus) copyStatus.hidden = true;
    });
  </script>
</BaseLayout>
